# Copy to .env and fill in. .env is gitignored.

# FRED API key — free, request at https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Data + warehouse
DATA_DIR=./data
DUCKDB_PATH=./data/warehouse.duckdb
RAW_DIR=./data/raw

# MLflow
MLFLOW_TRACKING_URI=file:./data/mlruns
MLFLOW_EXPERIMENT_NAME=regime-detection

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Drift alerting (free, no account)
NTFY_TOPIC=

# Logging
LOG_LEVEL=INFO

# Random seed for reproducibility
RANDOM_SEED=42

# Universe + history
UNIVERSE=SPY,QQQ,IWM,DIA,XLK,XLF,XLE,XLY,XLP,XLV,XLI,XLU,XLB,XLRE,XLC,VIX
HISTORY_START=2010-01-01
